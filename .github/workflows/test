name: Meta Ads Daily Report
  workflow_dispatch:
jobs:
  report:
    runs-on: ubuntu-latest
    steps:
    - uses: actions/checkout@v4
    - uses: actions/setup-python@v5
      with:
        python-version: '3.11'
    - run: pip install requests
    - run: python meta_test
      env:
        META_TOKEN: ${{ secrets.META_TOKEN }}
